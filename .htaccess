Options -MultiViews -Indexes
DirectoryIndex index.html

RewriteEngine On

# Serve real files directly.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If Next.js exported routes as folders, e.g. /about/index.html,
# serve /about and /about/ from that index.html.
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L,QSA]

# If Next.js exported routes as HTML files, e.g. /about.html,
# serve /about and /about/ from that HTML file.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L,QSA]

# Use the exported 404 page when Apache resolves a missing route.
ErrorDocument 404 /404.html